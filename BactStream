#!/usr/bin/env python3
import sys
import os
import subprocess
import shutil
from pathlib import Path
import argparse
import psutil
import re
import hashlib
from concurrent.futures import ThreadPoolExecutor, as_completed

def get_available_cores():
    slurm_cpus = os.environ.get("SLURM_CPUS_PER_TASK")
    if slurm_cpus and slurm_cpus.isdigit() and int(slurm_cpus) > 0:
        return int(slurm_cpus)
    return os.cpu_count() or 2

def get_resources(args):
    total_cores = get_available_cores()
    total_mem_gb = psutil.virtual_memory().available // (1024**3)
    jobs = args.jobs if args.jobs and args.jobs > 0 else 1
    if args.threads and args.threads > 0:
        threads = args.threads
    elif args.skip_assembly and args.jobs and args.jobs > 0:
        threads = max(1, total_cores // jobs)
    elif args.skip_assembly:
        threads = min(4, total_cores)
    else:
        threads = total_cores
    if args.skip_assembly and not (args.jobs and args.jobs > 0):
        jobs = max(1, total_cores // max(threads, 1))
    memory = args.memory if args.memory and args.memory > 0 else total_mem_gb
    memory_per_job = max(1, memory // jobs) if jobs > 1 else memory
    print(f"Detected resources: {total_cores} cores, {total_mem_gb}GB RAM")
    print(f"Using: {jobs} concurrent genome(s), {threads} thread(s) per genome, {memory_per_job}GB memory per genome")
    return threads, memory_per_job, jobs

def add_args(a):
    parser = argparse.ArgumentParser(description="Bacterial pipeline: reference annotation, assembly, annotation, variant calling, snpEff")
    parser.add_argument("--reference", "-r", help="Reference genome FASTA", required=True)
    parser.add_argument("--snpeff", "-s", default=False, help="Path to snpeff", required=False)
    parser.add_argument("--gatk", "-g", default=False, help="Path to gatk", required=False)
    parser.add_argument("--samtools", "-t", default=False, help="Path to samtools", required=False)
    parser.add_argument("--sra_ids", "-i", help="File with SRA IDs (one per line)", required=True)
    parser.add_argument("--trimgalore", "-T", default=False, help="Path to TrimGalore", required=False)
    parser.add_argument("--cutadapt", "-C", default=False, help="Path to Cutadapt", required=False)
    parser.add_argument("--spades", default="spades.py", help="Path to SPAdes", required=False)
    parser.add_argument("--bakta", default="bakta", help="Path to bakta", required=False)
    parser.add_argument("--baktadb", default="", help="Path to Bakta DB. Defaults to $BACTSTREAM_BAKTA_DB if set.", required=False)
    parser.add_argument("--reference_gbk", default="", help="Existing reference GenBank/GBFF annotation for snpEff DB build", required=False)
    parser.add_argument("--skip_sample_bakta", action="store_true", help="Skip Bakta annotation of per-sample SPAdes assemblies", required=False)
    parser.add_argument("--skip_assembly", action="store_true", help="Skip per-sample SPAdes assembly and Bakta annotation; map reads directly to the reference", required=False)
    parser.add_argument("--threads", type=int, default=0, help="Threads per tool (auto if 0)")
    parser.add_argument("--memory", type=int, default=0, help="Memory budget in GB; split across concurrent genomes (auto if 0)")
    parser.add_argument("--jobs", type=int, default=0, help="Concurrent genomes to process. Defaults to auto for --skip_assembly, otherwise 1.")
    return parser.parse_args(a)

def run_command(command):
    print(f"Running: {command}")
    subprocess.run(command, shell=True, check=True)

def read_reference_sequences(reference_file):
    sequences = {}
    current_name = None
    current_chunks = []
    with open(reference_file, "r") as fasta:
        for line in fasta:
            line = line.rstrip("\n")
            if line.startswith(">"):
                if current_name is not None:
                    sequences[current_name] = list("".join(current_chunks).upper())
                current_name = line[1:].strip().split()[0]
                current_chunks = []
            else:
                current_chunks.append(line.strip())
    if current_name is not None:
        sequences[current_name] = list("".join(current_chunks).upper())
    return sequences

def write_fasta(sequences, output_file, line_width=80, record_name=None):
    with open(output_file, "w") as fasta:
        for name, bases in sequences.items():
            fasta_name = record_name if record_name and len(sequences) == 1 else name
            if record_name and len(sequences) > 1:
                fasta_name = f"{record_name}|{name}"
            fasta.write(f">{fasta_name}\n")
            seq = "".join(bases)
            for i in range(0, len(seq), line_width):
                fasta.write(seq[i:i + line_width] + "\n")

def make_reference_aligned_consensus(reference_file, vcf_file, output_file, record_name=None):
    sequences = read_reference_sequences(reference_file)
    with open(vcf_file, "r") as vcf:
        for line in vcf:
            if line.startswith("#"):
                continue
            fields = line.rstrip("\n").split("\t")
            if len(fields) < 8:
                continue
            chrom, pos_text, _id, ref, alt_text, _qual, filt = fields[:7]
            if filt not in ("PASS", "."):
                continue
            if chrom not in sequences:
                continue
            alts = [alt for alt in alt_text.split(",") if alt and alt != "."]
            if not alts:
                continue
            alt = alts[0].upper()
            ref = ref.upper()
            pos = int(pos_text) - 1

            # Keep output in reference coordinates: SNPs/MNVs replace bases,
            # deleted reference bases become gaps, inserted alt-only sequence is ignored.
            shared_len = min(len(ref), len(alt))
            for offset in range(shared_len):
                if pos + offset < len(sequences[chrom]):
                    sequences[chrom][pos + offset] = alt[offset]
            if len(ref) > len(alt):
                for offset in range(len(alt), len(ref)):
                    if pos + offset < len(sequences[chrom]):
                        sequences[chrom][pos + offset] = "-"

    write_fasta(sequences, output_file, record_name=record_name)

def parse_java_major_version(version_output):
    match = re.search(r'version "([^"]+)"', version_output)
    if not match:
        return None
    version = match.group(1)
    if version.startswith("1."):
        parts = version.split(".")
        return int(parts[1]) if len(parts) > 1 and parts[1].isdigit() else None
    major = version.split(".", 1)[0]
    return int(major) if major.isdigit() else None

def get_java_major_version(java_path):
    try:
        result = subprocess.run(
            [str(java_path), "-version"],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=True
        )
    except (OSError, subprocess.CalledProcessError):
        return None
    return parse_java_major_version(result.stdout + result.stderr)

def find_java_executable(min_major=17):
    candidates = []
    seen = set()

    primary = shutil.which("java")
    if primary:
        candidates.append(primary)
        seen.add(primary)

    for extra in ["/usr/bin/java", "/bin/java", "/usr/local/bin/java"]:
        if Path(extra).exists() and extra not in seen:
            candidates.append(extra)
            seen.add(extra)

    for candidate in candidates:
        major = get_java_major_version(candidate)
        if major is not None and major >= min_major:
            print(f"java using: {candidate} (version {major})")
            return candidate

    print(f"No Java runtime >= {min_major} found. Checked: {', '.join(candidates) if candidates else 'none'}")
    sys.exit(1)

def find_executable(tool_name, custom_path):
    if custom_path and custom_path != "False":
        if custom_path.endswith(tool_name) or tool_name in custom_path:
            print(f"{tool_name} using: {custom_path}")
            return custom_path
        if not custom_path.endswith('/'):
            custom_path += '/'
        if Path(f"{custom_path}{tool_name}").exists():
            print(f"{tool_name} found at {custom_path}{tool_name}")
            return f"{custom_path}{tool_name}"
        print(f"{tool_name} path provided as: {custom_path}")
        return custom_path
    tool_path = shutil.which(tool_name)
    if tool_path:
        print(f"{tool_name} found in PATH: {tool_path}")
        return tool_path
    print(f"{tool_name} path not provided and not in PATH")
    sys.exit(1)

def find_snpeff_jar(custom_path):
    if custom_path and custom_path != "False":
        snpeff_path = Path(custom_path)
        if snpeff_path.is_file() and snpeff_path.name == "snpEff.jar":
            print(f"snpEff.jar using: {snpeff_path}")
            return str(snpeff_path)
        if snpeff_path.is_dir():
            jar = snpeff_path / "snpEff.jar"
            if jar.exists():
                print(f"snpEff.jar found at {jar}")
                return str(jar)
        print(f"snpEff.jar path provided as: {custom_path}")
        return custom_path

    tool_path = shutil.which("snpEff.jar")
    if tool_path:
        print(f"snpEff.jar found in PATH: {tool_path}")
        return tool_path

    conda_prefix = os.environ.get("CONDA_PREFIX")
    if conda_prefix:
        share_dir = Path(conda_prefix) / "share"
        candidates = sorted(share_dir.glob("snpeff*/snpEff.jar"))
        if candidates:
            print(f"snpEff.jar found in conda environment: {candidates[0]}")
            return str(candidates[0])

    print("snpEff.jar path not provided and not found in PATH or CONDA_PREFIX/share")
    sys.exit(1)

def find_bakta_db(custom_path):
    candidates = []
    if custom_path:
        candidates.append(custom_path)
    env_path = os.environ.get("BACTSTREAM_BAKTA_DB")
    if env_path:
        candidates.append(env_path)
    conda_prefix = os.environ.get("CONDA_PREFIX")
    if conda_prefix:
        candidates.extend([
            str(Path(conda_prefix) / "share" / "bakta" / "db-light"),
            str(Path(conda_prefix) / "share" / "bakta" / "db"),
        ])

    for candidate in candidates:
        path = Path(candidate).expanduser()
        if path.exists():
            print(f"Bakta DB using: {path}")
            return str(path)

    print("Bakta DB path not provided and no usable default was found.")
    print("Set BACTSTREAM_BAKTA_DB or pass --baktadb. You can install an env-local DB with:")
    print("  bash install_bakta_db.sh")
    sys.exit(1)

def get_completed_ids(sra_ids):
    completed = []
    for sra_id in sra_ids:
        annotated_vcf = Path(f"{sra_id}.filtered.snpeff.vcf")
        consensus_fasta = Path(f"{sra_id}.consensus.aln.fasta")
        if (
            annotated_vcf.exists()
            and annotated_vcf.stat().st_size > 0
            and consensus_fasta.exists()
            and consensus_fasta.stat().st_size > 0
        ):
            completed.append(sra_id)
    return completed

def find_first_existing_path(*paths):
    for path in paths:
        candidate = Path(path)
        if candidate.exists():
            return candidate
    return None

def write_first_token_reference_fasta(reference_file, db_name=None):
    normalized_name = f"{db_name}.reference.fna" if db_name else "customref.reference.fna"
    normalized_reference = Path(normalized_name)
    source = Path(reference_file)
    if normalized_reference.exists() and normalized_reference.stat().st_mtime >= source.stat().st_mtime:
        return normalized_reference

    with open(source, "r") as src, open(normalized_reference, "w") as dst:
        for line in src:
            if line.startswith(">"):
                token = line[1:].strip().split()[0]
                dst.write(f">{token}\n")
            else:
                dst.write(line)
    return normalized_reference

def reference_signature(reference_file):
    digest = hashlib.sha256()
    current_name = None
    current_length = 0

    def update_current():
        if current_name is not None:
            digest.update(current_name.encode())
            digest.update(b"\t")
            digest.update(str(current_length).encode())
            digest.update(b"\n")

    with open(reference_file, "r") as fasta:
        for line in fasta:
            if line.startswith(">"):
                update_current()
                current_name = line[1:].strip().split()[0]
                current_length = 0
            else:
                current_length += len(line.strip())
    update_current()
    return digest.hexdigest()[:12]

def snpeff_db_name(reference_file):
    return f"custom-db-{reference_signature(reference_file)}"

def reference_dict_path(reference_file):
    reference_path = Path(reference_file)
    return reference_path.with_suffix(".dict")

def prepare_reference_indexes(reference_file, gatk_path, samtools_path):
    bwa_suffixes = [".amb", ".ann", ".bwt", ".pac", ".sa"]
    if all(Path(f"{reference_file}{suffix}").exists() for suffix in bwa_suffixes):
        print("BWA index already exists, skipping bwa index.")
    else:
        run_command(f"bwa index {reference_file}")

    fai_path = Path(f"{reference_file}.fai")
    if fai_path.exists():
        print("samtools FASTA index already exists, skipping faidx.")
    else:
        run_command(f"{samtools_path} faidx {reference_file}")

    dict_path = reference_dict_path(reference_file)
    if dict_path.exists():
        print(f"GATK sequence dictionary already exists, skipping CreateSequenceDictionary: {dict_path}")
    else:
        run_command(f"{gatk_path} CreateSequenceDictionary -R {reference_file} -O {dict_path}")

def find_reference_gbk(reference_file, custom_path):
    candidates = []
    if custom_path:
        candidates.append(custom_path)

    reference_path = Path(reference_file)
    stem_path = reference_path.with_suffix("")
    candidates.extend([
        reference_path.with_suffix(".gbk"),
        reference_path.with_suffix(".gbff"),
        stem_path.with_suffix(".gbk"),
        stem_path.with_suffix(".gbff"),
    ])

    for candidate in candidates:
        path = Path(candidate).expanduser()
        if path.exists():
            return path
    return None

def build_snpEff(reference_file, reference_gbk, bakta_path, baktadb, snpeffpath, java_path, threads, memory):
    db_name = snpeff_db_name(reference_file)
    gbk_out = Path(f"{db_name}.gbk")
    if not gbk_out.exists():
        existing_reference_gbk = find_reference_gbk(reference_file, reference_gbk)
        if existing_reference_gbk is not None:
            print(f"Using existing reference GenBank annotation: {existing_reference_gbk}")
            shutil.copyfile(existing_reference_gbk, gbk_out)
        else:
            bakta_outdir = Path(f"{db_name}_bakta")
            bakta_gbk = find_first_existing_path(
                bakta_outdir / "customref.gbk",
                bakta_outdir / "customref.gbff",
            )
            if bakta_gbk is None:
                if not baktadb:
                    raise FileNotFoundError("No reference GenBank annotation found and no Bakta DB is available.")
                bakta_reference = write_first_token_reference_fasta(reference_file, db_name=db_name)
                print(f"Annotating reference genome with Bakta using first-token contig IDs: {bakta_reference}")
                run_command(f"{bakta_path} --db {baktadb} --output {bakta_outdir} --prefix customref --threads {threads} --keep-contig-headers {bakta_reference}")
                bakta_gbk = find_first_existing_path(
                    bakta_outdir / "customref.gbk",
                    bakta_outdir / "customref.gbff",
                )
            if bakta_gbk is None:
                raise FileNotFoundError(f"Bakta annotation finished but no GenBank output was found in {bakta_outdir}/")
            shutil.copyfile(bakta_gbk, gbk_out)
    else:
        print("Reference GBK already exists, skipping Bakta annotation.")

    snpeff_jar = Path(snpeffpath)
    snpeff_dir = snpeff_jar.parent if snpeff_jar.name == "snpEff.jar" else snpeff_jar
    snpeff_db_dir = snpeff_dir / "data" / db_name
    genes_gbk = snpeff_db_dir / "genes.gbk"
    if not snpeff_db_dir.exists() or not genes_gbk.exists():
        print(f"Building custom snpEff database {db_name} using Bakta GBK...")
        os.makedirs(snpeff_db_dir, exist_ok=True)
        shutil.copy(gbk_out, genes_gbk)
        config_path = snpeff_dir / "snpEff.config"
        config_line = f"{db_name}.genome: {db_name}\n"
        if config_path.exists():
            with open(config_path, "r") as cf:
                if config_line not in cf.read():
                    with open(config_path, "a") as cfa:
                        cfa.write("\n" + config_line)
        else:
            with open(config_path, "w") as cfa:
                cfa.write(config_line)
        run_command(f"{java_path} -jar {snpeff_jar} build -genbank -c {config_path} -v {db_name}")
    else:
        print(f"snpEff DB {db_name} already exists, skipping build.")
    return db_name

def process_sra_id(sra_id, args, tools, threads, memory):
    gatkPATH = tools["gatk"]
    trimgalore_path = tools["trimgalore"]
    cutadapt_path = tools["cutadapt"]
    spades_path = tools["spades"]
    bakta_path = tools["bakta"]
    baktadb = tools["baktadb"]
    snpeffpath = tools["snpeff"]
    snpeff_db = tools["snpeff_db"]
    java_path = tools["java"]

    print(f"Processing {sra_id}...")
    r1_file = f"{sra_id}_1.fastq"
    r2_file = f"{sra_id}_2.fastq"
    trimmed_r1_file = f"{sra_id}_1_val_1.fq.gz"
    trimmed_r2_file = f"{sra_id}_2_val_2.fq.gz"
    spades_outdir = None
    named_fasta = None

    try:
        run_command(f"fasterq-dump --split-files {sra_id}")

        run_command(f"{trimgalore_path} --path_to_cutadapt {cutadapt_path} --paired --cores {threads} --gzip {r1_file} {r2_file}")

        if args.skip_assembly:
            print(f"Skipping SPAdes assembly and per-sample Bakta annotation for {sra_id}.")
        else:
            spades_outdir = f"{sra_id}_spades_out"
            run_command(f"{spades_path} -1 {trimmed_r1_file} -2 {trimmed_r2_file} -o {spades_outdir} --threads {threads} --memory {memory}")
            assembled_fasta = f"{spades_outdir}/contigs.fasta"
            if not Path(assembled_fasta).exists():
                raise Exception(f"SPAdes failed: contigs.fasta not found for {sra_id}")
            named_fasta = f"{sra_id}.assembly.fasta"
            shutil.copyfile(assembled_fasta, named_fasta)

        if args.skip_sample_bakta or args.skip_assembly:
            print(f"Skipping per-sample Bakta annotation for {sra_id}.")
        else:
            run_command(f"{bakta_path} --db {baktadb} --output {sra_id}_bakta --prefix {sra_id} --threads {threads} {named_fasta}")
            bakta_gbk = find_first_existing_path(f"{sra_id}_bakta/{sra_id}.gbk", f"{sra_id}_bakta/{sra_id}.gbff")
            bakta_gff = find_first_existing_path(f"{sra_id}_bakta/{sra_id}.gff", f"{sra_id}_bakta/{sra_id}.gff3")
            if bakta_gbk is not None:
                shutil.move(bakta_gbk, f"{sra_id}.bakta.gbk")
            if bakta_gff is not None:
                shutil.move(bakta_gff, f"{sra_id}.bakta.gff")

        run_command(f'bwa mem -t {threads} -R "@RG\\tID:{sra_id}\\tPL:ILLUMINA\\tLB:lib1\\tSM:{sra_id}" {args.reference} {trimmed_r1_file} {trimmed_r2_file} > {sra_id}_aln.sam')
        run_command(f'{gatkPATH} SortSam -I {sra_id}_aln.sam -O {sra_id}_sorted.bam -SO coordinate')
        run_command(f'{gatkPATH} MarkDuplicates -I {sra_id}_sorted.bam -O {sra_id}_dedup.bam -M {sra_id}_metrics.txt')
        run_command(f'{gatkPATH} BuildBamIndex -I {sra_id}_dedup.bam')
        run_command(f'{gatkPATH} HaplotypeCaller -R {args.reference} -I {sra_id}_dedup.bam --native-pair-hmm-threads {threads} -ploidy 1 -O {sra_id}_raw_gVCF.vcf -ERC GVCF')
        run_command(f'{gatkPATH} GenotypeGVCFs -R {args.reference} --variant {sra_id}_raw_gVCF.vcf -O {sra_id}_raw.vcf')
        filtered_vcf = f"{sra_id}.filtered.vcf"
        run_command(f'{gatkPATH} VariantFiltration -R {args.reference} -V {sra_id}_raw.vcf -O {filtered_vcf} --filter-expression "QUAL < 30.0" --filter-name "LowQual"')

        annotated_vcf = f"{filtered_vcf.replace('.vcf', '.snpeff.vcf')}"
        snpeff_jar = Path(snpeffpath)
        snpeff_dir = snpeff_jar.parent if snpeff_jar.name == "snpEff.jar" else snpeff_jar
        run_command(f'{java_path} -Xmx{memory}G -jar {snpeff_jar} -c {snpeff_dir / "snpEff.config"} {snpeff_db} {filtered_vcf} > {annotated_vcf}')
        consensus_fasta = f"{sra_id}.consensus.aln.fasta"
        make_reference_aligned_consensus(args.reference, filtered_vcf, consensus_fasta, record_name=sra_id)
        print(f"Completed {sra_id}: outputs = {annotated_vcf}, {consensus_fasta}")
        return True
    finally:
        for temp_file in [
            r1_file, r2_file, trimmed_r1_file, trimmed_r2_file,
            f"{sra_id}_aln.sam", f"{sra_id}_sorted.bam", f"{sra_id}_metrics.txt",
            f"{sra_id}_dedup.bam", f"{sra_id}_dedup.bai", f"{sra_id}_raw_gVCF.vcf", f"{sra_id}_raw.vcf",
            named_fasta, spades_outdir, f"{sra_id}_bakta"
        ]:
            if temp_file is None:
                continue
            if Path(temp_file).is_file():
                os.remove(temp_file)
            elif Path(temp_file).is_dir():
                shutil.rmtree(temp_file)

if __name__ == "__main__":
    args = add_args(sys.argv[1:])
    threads, memory, jobs = get_resources(args)

    snpeffpath = find_snpeff_jar(args.snpeff)
    gatkPATH = find_executable("gatk", args.gatk)
    samtoolsPATH = find_executable("samtools", args.samtools)
    trimgalore_path = find_executable("trim_galore", args.trimgalore)
    cutadapt_path = find_executable("cutadapt", args.cutadapt)
    spades_path = None if args.skip_assembly else find_executable("spades.py", args.spades)
    bakta_path = find_executable("bakta", args.bakta)
    java_path = find_java_executable()
    reference_gbk = find_reference_gbk(args.reference, args.reference_gbk)
    baktadb = "" if reference_gbk is not None and args.skip_sample_bakta else find_bakta_db(args.baktadb)

    os.environ["PATH"] = f"{Path(java_path).parent}{os.pathsep}{os.environ['PATH']}"
    snpeff_db = build_snpEff(args.reference, args.reference_gbk, bakta_path, baktadb, snpeffpath, java_path, threads, memory)

    prepare_reference_indexes(args.reference, gatkPATH, samtoolsPATH)

    with open(args.sra_ids, "r") as f:
        sra_ids = [line.strip() for line in f if line.strip()]
    completed_ids = get_completed_ids(sra_ids)
    remaining_ids = [s for s in sra_ids if s not in completed_ids]
    if not remaining_ids:
        print("All genomes have been processed.")
        sys.exit(0)

    print(f"Resuming from SRA ID: {remaining_ids[0]}")
    tools = {
        "gatk": gatkPATH,
        "trimgalore": trimgalore_path,
        "cutadapt": cutadapt_path,
        "spades": spades_path,
        "bakta": bakta_path,
        "baktadb": baktadb,
        "snpeff": snpeffpath,
        "snpeff_db": snpeff_db,
        "java": java_path,
    }
    if jobs == 1:
        for sra_id in remaining_ids:
            try:
                process_sra_id(sra_id, args, tools, threads, memory)
            except Exception as e:
                print(f"Error processing {sra_id}: {e}")
                continue
    else:
        print(f"Processing {len(remaining_ids)} genome(s) with {jobs} concurrent stream(s).")
        with ThreadPoolExecutor(max_workers=jobs) as executor:
            futures = {
                executor.submit(process_sra_id, sra_id, args, tools, threads, memory): sra_id
                for sra_id in remaining_ids
            }
            for future in as_completed(futures):
                sra_id = futures[future]
                try:
                    future.result()
                except Exception as e:
                    print(f"Error processing {sra_id}: {e}")

    print("\n\nAll tasks completed!\n\n")
